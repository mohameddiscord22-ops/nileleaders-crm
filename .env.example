# ============================================================================
# Database Configuration
# ============================================================================
# MySQL database connection URL
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://user:password@localhost:3306/nileleaders_crm

# ============================================================================
# Authentication
# ============================================================================
# JWT Secret for session tokens (use a strong random string in production)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-here-change-this-in-production
SESSION_SECRET=your-super-secret-key-here-change-this-in-production

# ============================================================================
# Environment
# ============================================================================
# Set to 'production' for production deployments
NODE_ENV=development

# URL of the deployed frontend (for CORS security)
# Example: https://your-app.web.app
FRONTEND_URL=

# ============================================================================
# Frontend Configuration (for Vite build)
# ============================================================================
# Backend API URL (used when building frontend)
# Leave empty for same-origin requests (when frontend and backend are on same domain)
# Set to your backend URL when deploying frontend separately
VITE_API_URL=

# ============================================================================
# S3 / Cloud Storage (Optional - for file uploads)
# ============================================================================
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ============================================================================
# Optional: OAuth Configuration (if using Manus OAuth)
# ============================================================================
# OAUTH_SERVER_URL=https://oauth.example.com
# OWNER_OPEN_ID=your-owner-id

# ============================================================================
# Optional: Forge API (if using image generation)
# ============================================================================
# BUILT_IN_FORGE_API_URL=https://forge.example.com
# BUILT_IN_FORGE_API_KEY=your-api-key

# ============================================================================
# Port Configuration
# ============================================================================
# Port for the Express server (default: 3000)
PORT=3000
